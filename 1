-- 2. HÀM KÍCH HOẠT CHỨC NĂNG (LOAD ENGINE)
local function CreateBtn(name, script_str)
    local B = Instance.new("TextButton", Scroll)
    B.Size = UDim2.new(0, 400, 0, 50)
    B.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    B.Text = name
    B.TextColor3 = Color3.new(1,1,1)
    B.Font = "GothamBold"
    B.TextSize = 14
    Instance.new("UICorner", B)
    
    local S = Instance.new("UIStroke", B)
    S.Color = Color3.fromRGB(0, 170, 255)
    S.ApplyStrokeMode = "Border"

    B.MouseButton1Click:Connect(function()
        B.Text = "ĐANG KÍCH HOẠT... ĐỢI 5 GIÂY"
        loadstring(game:HttpGet(script_str))()
        B.Text = name .. " [ĐÃ CHẠY]"
        B.BackgroundColor3 = Color3.fromRGB(0, 100, 0)
    end)
end

